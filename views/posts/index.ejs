<%- include('../partials/header') %>

<div class="container">

  <div class="page-hero">
    <span class="eyebrow">Daily ideas, essays, and notes</span>
    <h1>InkSpace</h1>
    <p class="subtitle">A bright little corner for thoughtful writing, personal stories, and the ideas you want to revisit later.</p>
    <div class="hero-actions">
      <a href="/posts/new" class="btn btn-primary">Start Writing</a>
      <a href="#posts-list" class="btn btn-secondary">Browse Posts</a>
    </div>
  </div>

  <% if (posts && posts.length > 0) { %>
    <p class="post-count" id="posts-list">
      <strong><%= posts.length %></strong> articles published
    </p>
  <% } %>

  <% if (!posts || posts.length === 0) { %>
    <div class="posts-empty">
      <h2>No posts available yet...</h2>
      <p>Start your journey by writing your first blog post and give this page its first spark of life.</p>
      <a href="/posts/new" class="btn btn-primary">✍ Write Your First Post</a>
    </div>

  <% } else { %>
    <div class="posts-grid">

      <% posts.forEach(post => { %>
        <a href="/posts/<%= post.id %>" class="post-card">
          <div class="post-card-accent"></div>
          <div class="post-card-body">
            <div class="post-card-meta">
              <%= new Date(post.created_at).toLocaleDateString('en-IN', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              }) %>
            </div>
            
            <h2 class="post-card-title"><%= post.title %></h2>
            
            <p class="post-card-excerpt">
              <%= post.content ? post.content.substring(0, 180) : '' %>
              <%= post.content && post.content.length > 180 ? '...' : '' %>
            </p>
          </div>

          <div class="post-card-arrow">Read story →</div>
        </a>
      <% }) %>

    </div>
  <% } %>

</div>

<%- include('../partials/footer') %>
